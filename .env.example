
# Web Push (VAPID). Generate with: npx web-push generate-vapid-keys --json
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:support@svoi-connect.ru

# Отдельный магазин ЮКассы для платежей с сайта svoiweb.ru
# (бот остаётся на YOOKASSA_SHOP_ID / YOOKASSA_SECRET_KEY).
# Пока не заданы — сайт фолбэчится на ботовский магазин.
YOOKASSA_WEB_SHOP_ID=
YOOKASSA_WEB_SECRET_KEY=
# true — только после того, как ЮКасса включит «автоплатежи» (рекурренты)
# на магазине сайта; до этого save_payment_method роняет платёж с forbidden.
YOOKASSA_WEB_RECURRING=false
